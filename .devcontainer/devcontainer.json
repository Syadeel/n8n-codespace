{
  "name": "n8n Development",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "n8n",
  "workspaceFolder": "/home/node",
  "forwardPorts": [5678],
  "postCreateCommand": "echo 'n8n is running on http://localhost:5678'",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint"
      ]
    }
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {}
  }
}
